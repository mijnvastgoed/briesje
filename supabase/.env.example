# Copy to .env.local (never commit it). Only Stripe test-mode keys are accepted.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
EXPECTED_STRIPE_LIVEMODE=false
STRIPE_MODE=test
LIVE_PAYMENTS_ENABLED=false
CHECKOUT_ENABLED=false
ALLOWED_ORIGINS=http://localhost:5173
CHECKOUT_SUCCESS_URL=http://localhost:5173/bestelling?session_id={CHECKOUT_SESSION_ID}
CHECKOUT_CANCEL_URL=http://localhost:5173/winkelmand
SUPPLIER_SYNC_ENABLED=false
# Must be an HTTPS endpoint documented/authorized by the official supplier API agreement.
SUPPLIER_API_BASE_URL=https://api.example.invalid
SUPPLIER_API_ALLOWED_HOST=api.example.invalid
SUPPLIER_API_KEY=replace-with-official-api-credential
SUPPLIER_SYNC_SECRET=replace-with-high-entropy-scheduler-secret
FULFILLMENT_ENABLED=false
FULFILLMENT_CONTRACT_APPROVED=false
FULFILLMENT_GATEWAY_IDEMPOTENCY_CONFIRMED=false
FULFILLMENT_WORKER_SECRET=replace-with-separate-high-entropy-secret
# Approved gateway must sign/authorize the official TOP request and enforce Idempotency-Key.
FULFILLMENT_API_BASE_URL=https://api.example.invalid
FULFILLMENT_API_ALLOWED_HOST=api.example.invalid
FULFILLMENT_API_KEY=replace-with-official-api-or-approved-gateway-credential
ALIEXPRESS_ORDER_API_METHOD=aliexpress.trade.buy.placeorder
ALIEXPRESS_LOGISTICS_SERVICE_NAME=replace-with-approved-tracked-service
